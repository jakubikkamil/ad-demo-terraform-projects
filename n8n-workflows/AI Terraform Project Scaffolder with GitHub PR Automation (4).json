      "parameters": {
        "jsCode": "// Prepare branch creation data\nconst projectName = $('Check Validation Status').item.json.output.validated_spec.project_name;\nconst mainSha = $input.item.json.object.sha;\nconst timestamp = new Date().toISOString().replace(/[-:]/g, '').split('.')[0].replace('T', '-');\nconst branchName = `feature/${projectName}-${timestamp}`;\n\nreturn [{\n  json: {\n    branchName: branchName,\n    mainSha: mainSha,\n    projectName: projectName,\n    files: $('Collect Copied Files').item.json\n  }\n}];"
      },
      "id": "e042179c-e678-4855-8b63-913a0d36dac5",
      "name": "Prepare Branch Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5408,
        32
      ]
    },
    {
      "parameters": {
        "jsCode": "// Get all incoming branch items\nconst items = $input.all();\n\n// Extract only the JSON payloads\nconst branches = items.map(item => item.json);\n\n// Get project name from previous node\nconst projectName = $('Check Validation Status').first().json.output.validated_spec.project_name;\n\n\n// Check if any branch name includes the project name\nconst matchingBranch = branches.find(branch => \n  branch.name.includes(projectName)\n);\n\nif (matchingBranch) {\n  throw new Error(\n    `Branch with project name ${projectName} already exists: ${matchingBranch.name}`\n  );\n}\n\n// Continue workflow if no branch found\nreturn items;"
      },
      "id": "f10abd03-0c47-4923-a423-bd853bc8b64a",
      "name": "Check Branch Name Match",
