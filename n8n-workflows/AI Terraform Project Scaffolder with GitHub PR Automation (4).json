    {
      "parameters": {
        "jsCode": "// Extract all file paths from project1/terraform directory\nconst tree = $input.item.json.tree;\nconst projectName = $('Check Validation Status').item.json.output.validated_spec.project_name;\n\n// Filter files that are in projects/project1/terraform/\nconst project1Files = tree.filter(item => \n  item.type === 'blob' && \n  item.path.startsWith('projects/project1/terraform/')\n);\n\n// Map to new paths and include download URLs\nconst filesToCopy = project1Files.map(file => ({\n  originalPath: file.path,\n  newPath: file.path.replace('projects/project1/', `projects/${projectName}/`),\n  sha: file.sha,\n  url: file.url\n}));\n\nreturn [{ json: { files: filesToCopy, projectName } }];"
      },
