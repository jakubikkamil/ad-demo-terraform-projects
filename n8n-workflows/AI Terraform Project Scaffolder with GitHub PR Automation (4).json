    {
      "parameters": {
        "jsCode": "const projectName = $('Extract File Paths').item.json.projectName;\n\nreturn $input.all().map(item => {\n\n  // Decode base64 content\n  let content = Buffer\n    .from(item.json.content.replace(/\\n/g, ''), 'base64')\n    .toString('utf-8');\n\n  const path = item.json.newPath;\n\n  // Modify backend.tf key value\n  if (path && path.endsWith('backend.tf')) {\n    content = content.replace(\n      /(key\\s*=\\s*\")[^\"]*(\")/,\n      `$1${projectName}.terraform.tfstate$2`\n    );\n  }\n\n  return {\n    json: {\n      path: path,\n      content: content,\n      projectName: projectName\n    }\n  };\n\n});"
      },
