      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"status\": {\n      \"type\": \"string\",\n      \"enum\": [\"complete\", \"needs_clarification\", \"needs_approval\"]\n    },\n    \"intent\": {\n      \"type\": \"string\",\n      \"enum\": [\"deployment_request\", \"infrastructure_question\", \"mixed\"]\n    },\n    \"summary\": {\n      \"type\": \"string\"\n    },\n    \"follow_up_questions\": {\n      \"type\": \"array\",\n      \"items\": { \"type\": \"string\" }\n    },\n    \"validated_spec\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"project_name\": { \"type\": \"string\" },\n        \"modules\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" }\n        },\n        \"environment\": { \"type\": \"string\" },\n        \"config\": { \"type\": \"object\" }\n      },\n      \"required\": [\n        \"project_name\",\n        \"modules\",\n        \"environment\",\n        \"variables\"\n      ],\n      \"additionalProperties\": true\n    }\n  },\n  \"required\": [\"status\", \"intent\", \"summary\", \"follow_up_questions\"],\n  \"additionalProperties\": false\n}"
      },
